# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
PORT=3000
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# =============================================================================
# Database
# =============================================================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/pages_of_you?schema=public"

# =============================================================================
# JWT
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_secret_change_me
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=your_refresh_secret_change_me
JWT_REFRESH_EXPIRES_IN=30d

# Admin-specific JWT (completely isolated from the user JWT secrets)
JWT_ADMIN_SECRET=your_admin_secret_change_me
JWT_ADMIN_EXPIRES_IN=8h

# =============================================================================
# OTP
# =============================================================================
# TTL for OTP code in seconds (default: 300 = 5 minutes)
OTP_CODE_TTL=300
# Maximum verification attempts per code
OTP_MAX_ATTEMPTS=3

# =============================================================================
# Cloudflare R2 (S3 Compatible)
# =============================================================================
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=pages-of-you
# Public CDN domain for R2 bucket (e.g. pub-xxx.r2.dev or your custom domain)
R2_PUBLIC_URL=https://pub-xxx.r2.dev
