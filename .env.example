# Backend API URL (must include /api prefix)
#
# Vite loads env by mode:
#   npm run dev   → .env.development (localhost)
#   npm run build → .env.production  (Render / production host)
#
# Optional: create .env.local to override on your machine (gitignored).

# .env.development
VITE_API_BASE_URL=http://localhost:3000/api

# .env.production
# VITE_API_BASE_URL=https://pagesofyou.onrender.com/api
#
# Optional: public origin for /uploads/* when static files are not on the API host
# (e.g. API at https://api.example.com, files at https://example.com)
# VITE_ASSETS_BASE_URL=https://pagesofyou.onrender.com
